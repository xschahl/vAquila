# Required: host path mounted into managed vLLM containers
# Windows example: C:/Users/<user>/huggingface
# Linux example: /home/<user>/.cache/huggingface
VAQ_HF_CACHE_HOST_PATH=C:/Users/<user>/GitRepository/vAquila/tmp/huggingface

# Optional: pin a specific public beta image published in GHCR
VAQ_IMAGE=ghcr.io/xschahl/vaquila:v0.1.0-beta.1

# Optional runtime image overrides used by vaq run
VAQ_VLLM_IMAGE=vllm/vllm-openai:latest
VAQ_VLLM_CPU_IMAGE=vllm/vllm-openai-cpu:latest
# Optional: limit vLLM CPU KV cache allocation (GiB) to reduce RAM pressure
VAQ_VLLM_CPU_KVCACHE_SPACE=4

# Optional defaults
VAQ_SECURITY_VRAM_BUFFER_GB=1.5
VAQ_DEFAULT_HOST_PORT=8000
VAQ_INFERENCE_BASE_URL=http://host.docker.internal:8000
