# Copie ce fichier vers .env puis adapte les valeurs.
# IMPORTANT: ce chemin doit être un chemin absolu lisible par le daemon Docker hôte.
VAQ_HF_CACHE_HOST_PATH=/home/your-user/.cache/huggingface

# Optionnel
VAQ_VLLM_IMAGE=vllm/vllm-openai:latest
# Use a CPU-compatible vLLM OpenAI image for --device cpu.
# Official x86_64 image from vLLM docs:
VAQ_VLLM_CPU_IMAGE=vllm/vllm-openai-cpu:latest-x86_64
VAQ_SECURITY_VRAM_BUFFER_GB=1.5
VAQ_DEFAULT_HOST_PORT=8000
VAQ_INFERENCE_BASE_URL=http://host.docker.internal:8000
